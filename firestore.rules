// Firestore Security Rules for AGZ v2
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requester signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: is the requester an admin? (checks admins/{uid} document existence)
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper: is the requester the owner of the given uid?
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── users ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── basvuru_durumlari ──────────────────────────────────────────────────
    match /basvuru_durumlari/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── belgeler ───────────────────────────────────────────────────────────
    match /belgeler/{belgeId} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.kullaniciId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.kullaniciId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── projeler ───────────────────────────────────────────────────────────
    match /projeler/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── admins ─────────────────────────────────────────────────────────────
    // Only admins can read admin list; writes done via Firebase Admin SDK only
    match /admins/{uid} {
      allow read:  if isAdmin() || isOwner(uid);
      allow write: if false;
    }
  }
}
